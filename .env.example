# ============================================================
# VAI Radiology Assessment — Environment Variables
# ============================================================
# Copy this file to .env (backend) and set actual values.
# NEVER commit your real .env file to version control.
# ============================================================

# ──────────────────────────────────────────────────────────
# Django / Backend (set these on Render)
# ──────────────────────────────────────────────────────────

# Django secret key — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Set to any value to disable DEBUG mode (e.g. on Render)
RENDER=true

# PostgreSQL connection string (auto-set by Render when linked database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Full URL of your deployed Vercel frontend (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# Path to the YOLO segmentation model weights file
YOLO_MODEL_PATH=yolov8n-seg.pt

# ──────────────────────────────────────────────────────────
# Next.js / Frontend (set these on Vercel)
# ──────────────────────────────────────────────────────────

# Full URL of your deployed Render backend API (WITH trailing slash)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api/
